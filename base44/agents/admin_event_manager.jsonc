    {
      "function_name": "generateQuote",
      "description": "\u05d9\u05e6\u05d9\u05e8\u05ea \u05d4\u05e6\u05e2\u05ea \u05de\u05d7\u05d9\u05e8 HTML \u05dc\u05d0\u05d9\u05e8\u05d5\u05e2. \u05e4\u05e8\u05de\u05d8\u05e8\u05d9\u05dd: {eventId, includeIntro, includePaymentTerms, includeSchedule}"
    },
    {
      "function_name": "generateQuotePdf",
      "description": "\u05d9\u05e6\u05d9\u05e8\u05ea \u05d4\u05e6\u05e2\u05ea \u05de\u05d7\u05d9\u05e8 \u05db\u05e7\u05d5\u05d1\u05e5 PDF \u05dc\u05d0\u05d9\u05e8\u05d5\u05e2. \u05e4\u05e8\u05de\u05d8\u05e8\u05d9\u05dd: {eventId, includeIntro, includePaymentTerms, includeSchedule}. \u05de\u05d7\u05d6\u05d9\u05e8 {pdf_url, fileName}"
    },
    {
      "function_name": "generateManualQuotePdf",
      "description": "\u05d9\u05e6\u05d9\u05e8\u05ea PDF \u05e9\u05dc \u05d4\u05e6\u05e2\u05ea \u05de\u05d7\u05d9\u05e8 \u05d9\u05d3\u05e0\u05d9\u05ea. \u05e4\u05e8\u05de\u05d8\u05e8\u05d9\u05dd: {quoteId}. \u05de\u05d7\u05d6\u05d9\u05e8 {pdf_url, fileName}"
    }
  ],
  "whatsapp_greeting": "\u05e9\u05dc\u05d5\u05dd! \ud83d\udc4b \u05d0\u05e0\u05d9 \u05d4\u05e2\u05d5\u05d6\u05e8 \u05d4\u05d7\u05db\u05dd \u05e9\u05dc Pulse \u05dc\u05e0\u05d9\u05d4\u05d5\u05dc \u05d0\u05d9\u05e8\u05d5\u05e2\u05d9\u05dd.\n\u05d0\u05e0\u05d9 \u05d9\u05db\u05d5\u05dc \u05dc\u05e2\u05d6\u05d5\u05e8 \u05dc\u05da \u05dc\u05d9\u05e6\u05d5\u05e8 \u05d5\u05dc\u05e0\u05d4\u05dc \u05d0\u05d9\u05e8\u05d5\u05e2\u05d9\u05dd, \u05e9\u05d9\u05e8\u05d5\u05ea\u05d9\u05dd, \u05d7\u05d1\u05d9\u05dc\u05d5\u05ea, \u05ea\u05e9\u05dc\u05d5\u05de\u05d9\u05dd \u05d5\u05d4\u05e6\u05e2\u05d5\u05ea \u05de\u05d7\u05d9\u05e8 - \u05d4\u05db\u05dc \u05de\u05ea\u05d5\u05da \u05d4\u05e6'\u05d0\u05d8.\n\n\u05de\u05d4 \u05ea\u05e8\u05e6\u05d4 \u05dc\u05e2\u05e9\u05d5\u05ea?",
  "telegram_greeting": "\u05e9\u05dc\u05d5\u05dd! \ud83d\udc4b \u05d0\u05e0\u05d9 \u05d4\u05e2\u05d5\u05d6\u05e8 \u05d4\u05d7\u05db\u05dd \u05e9\u05dc Pulse \u05dc\u05e0\u05d9\u05d4\u05d5\u05dc \u05d0\u05d9\u05e8\u05d5\u05e2\u05d9\u05dd.\n\u05d0\u05e0\u05d9 \u05d9\u05db\u05d5\u05dc \u05dc\u05e2\u05d6\u05d5\u05e8 \u05dc\u05da \u05dc\u05d9\u05e6\u05d5\u05e8 \u05d5\u05dc\u05e0\u05d4\u05dc \u05d0\u05d9\u05e8\u05d5\u05e2\u05d9\u05dd, \u05e9\u05d9\u05e8\u05d5\u05ea\u05d9\u05dd, \u05d7\u05d1\u05d9\u05dc\u05d5\u05ea, \u05ea\u05e9\u05dc\u05d5\u05de\u05d9\u05dd \u05d5\u05d4\u05e6\u05e2\u05d5\u05ea \u05de\u05d7\u05d9\u05e8 - \u05d4\u05db\u05dc \u05de\u05ea\u05d5\u05da \u05d4\u05e6'\u05d0\u05d8.\n\n\u05de\u05d4 \u05ea\u05e8\u05e6\u05d4 \u05dc\u05e2\u05e9\u05d5\u05ea?",
  "name": "admin_event_manager"
}